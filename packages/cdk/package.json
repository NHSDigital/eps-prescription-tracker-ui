{
  "name": "cdk",
  "version": "0.1.0",
  "scripts": {
    "cdk-synth": "cdk synth --output ../../cdk.out --quiet --app \"tsx bin/${CDK_APP_NAME}.ts\"",
    "cdk-deploy": "cdk deploy ${CDK_STACK_NAME} --app \"tsx bin/${CDK_APP_NAME}.ts\" --exclusively --require-approval ${REQUIRE_APPROVAL}",
    "cdk-watch": "cdk deploy --app \"tsx bin/${CDK_APP_NAME}.ts\" --watch --all --require-approval never",
    "lint": "eslint  --max-warnings 0 --fix --config ../../eslint.config.mjs ."
  },
  "dependencies": {
    "@nhsdigital/eps-cdk-constructs": "^1.4.3",
    "@nhsdigital/eps-deployment-utils": "^1.4.3",
    "aws-cdk": "^2.1112.0",
    "aws-cdk-lib": "^2.244.0",
    "cdk-nag": "^2.37.55",
    "constructs": "^10.4.5",
    "tsx": "^4.21.0"
  }
}
